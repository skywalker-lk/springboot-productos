# API URL para conectar con Spring Boot
# Cambiar según tu configuración de backend
# Sin /api: nuestro backend Spring Boot no tiene context-path
VITE_API_URL=http://localhost:8080

# Si usás un puerto diferente, ajustá:
# VITE_API_URL=http://localhost:9090/api
# VITE_API_URL=http://192.168.100.7:8080/api

# EmailJS (Para formulario de contacto)
# Registrate en https://www.emailjs.com/ para obtener estos valores
VITE_EMAILJS_SERVICE_ID=tu_service_id
VITE_EMAILJS_TEMPLATE_ID=tu_template_id
VITE_EMAILJS_PUBLIC_KEY=tu_public_key
